# 使用官方 Python 3.11 slim 作为基础镜像
# FROM python:3.11-slim
FROM pytorch/pytorch:2.6.0-cuda12.6-cudnn9-devel
# FROM nvidia/cuda:12.6.3-cudnn-runtime-ubuntu22.04
# FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04
# FROM pytorch/pytorch:2.3.1-cuda12.1-cudnn8-runtime
# FROM pytorch/pytorch:2.6.0-cuda12.6-cudnn9-runtime
# RUN apt-get update && \
#     apt-get install -y --no-install-recommends \
#         git &&\
#     rm -rf /var/lib/apt/lists/*

# RUN git clone https://github.com/microsoft/VibeVoice.git
COPY ./VibeVoice /VibeVoice
WORKDIR /VibeVoice



RUN pip install --upgrade pip && \
    pip install -e . -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host=mirrors.aliyun.com && \
    pip install flash-attn --no-build-isolation && \
    rm -rf /root/.cache/pip /root/.cache /tmp/*