# ============================
# 基本服务配置
# ============================
# 当前环境: dev / test / prod
ENVIRONMENT=dev

BASE_URL=http://localhost:8000
API_KEY=123

# ============================
# 存储相关
# ============================
CACHE_DIR=/data/agi
LANGCHAIN_DB_PATH=sqlite:///data/agi/langchain.db
FILE_STORAGE_URL=file:///data/agi/files
BROWSER_STORAGE_PATH=/data/agi/browser

# ============================
# 模型路径与 LLM 配置
# ============================
MODEL_PATH=/data/model

# Ollama LLM
OLLAMA_API_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODE=qwen3:4b-instruct
OLLAMA_SMALL_MODE=qwen3:4b-thinking
LLM_WITH_NO_THINKING=/no_think
OPENAI_API_KEY=xxx

# Embedding
RAG_EMBEDDING_MODEL=bge
RAG_EMBEDDING_MODEL_PATH=/data/model/Qwen3-Embedding-0.6B
EMBEDDING_BASE_URL=http://localhost:8006
CLUSTER_ALGO=dpmeans
COMPUTE_TYPE=float16

# ============================
# Speech-to-Text 配置
# ============================
WHISPER_GPU_ENABLE=true
WHISPER_MODEL_DIR=/data/model/wisper-v3-turbo-c2
WHISPER_MODLE_NAME=large
WHISPER_BASE_URL=http://localhost:8003/v1/

# ============================
# TTS 配置
# ============================
TTS_GPU_ENABLE=true
TTS_MODEL_DIR=/data/model/cosyvoice/CosyVoice2-0.5B
TTS_MODLE_NAME=cosyvoice
TTS_SPEAKER_WAV=asset/zero_shot_prompt.wav
TTS_BASE_URL=http://localhost:8002/v1/

# ============================
# Image 配置
# ============================
IMAGE_TO_IMAGE_MODEL_PATH=/data/model/sdxl-turbo
TEXT_TO_IMAGE_MODEL_PATH=/data/model/sdxl-turbo
TEXT_TO_IMAGE_MODEL_NAME=sdxl
IMAGE_GEN_BASE_URL=http://localhost:8001/v1/

# ============================
# Multi-model 配置
# ============================
MULTI_MODEL_PATH=/data/model/Qwen2.5-Omni-3B
MULTI_MODEL_NAME=gemma
MULTI_MODEL_BASE_URL=http://localhost:8005/v1/

# ============================
# Web / 外部 API 配置
# ============================
EXA_API_KEY=
TAVILY_API_KEY=
SEARXNG_BASE_URL=http://localhost:8091
ALPHAVANTAGE_API_KEY=

# ============================
# 系统参数
# ============================
STOP_WORDS_PATH=./asset/stopwords.txt
AGI_DEBUG=true
AGI_LONG_TERM_MEMORY_ENABLED=true
AGI_MEMORY_PATH_PREFIX=/memories/
AGI_ASSISTANT_ID=deepagent_main
AGI_TENANT_ID=default_tenant

# ============================
# LangChain 调试
# ============================
LANGCHAIN_DEBUG=true
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agi